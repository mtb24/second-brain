# =============================================================
# Second Brain — Environment Variables
# Copy this to .env and fill in all values
# NEVER commit .env to git
# =============================================================

# Postgres
POSTGRES_DB=brain
POSTGRES_USER=brain
POSTGRES_PASSWORD=change-me-to-a-strong-password

# API auth (generate with: openssl rand -hex 32)
API_SECRET=change-me
MCP_SECRET=change-me

# Backblaze B2 (free tier: 10GB storage, 1GB/day download)
# Create a bucket at backblaze.com, then generate an App Key
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET=your-bucket-name
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com  # change region to match yours

# Ollama (running on host, not in Docker)
OLLAMA_URL=http://host-gateway:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# Your domain (for Nginx + Certbot)
DOMAIN=brain.yourdomain.com
