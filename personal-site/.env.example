# Copy to ../.env (repo root) or .env here — never commit real values.
# See BRAIN.md for the full ~/brain/.env shape.

# Backblaze (adventures upload script uses B2_KEY_ID + B2_APP_KEY)
# B2_BUCKET_NAME=kendowney-assets
# B2_PUBLIC_URL=https://f005.backblazeb2.com/file/kendowney-assets

# Optional: override B2 friendly URL root in dev/build (default in adventureManifest.ts)
# VITE_ADVENTURE_B2_BASE=https://f005.backblazeb2.com/file/kendowney-assets/adventures
